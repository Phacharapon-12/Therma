        "\n",
        "            # Select the section of nodes belonging to the currently 'equilibrated' TSU unit\n",
        "            start_node = active_unit * self.unit_size\n",
        "            end_node = (active_unit + 1) * self.unit_size\n",
        "            unit_node_logits = node_logits[start_node:end_node]\n",
        "\n",
        "            # Calculate partition functions for the active unit\n",
        "            unit_energies = jax.nn.logsumexp(unit_node_logits * beta, axis=-1)\n",
        "\n",
