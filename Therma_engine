        "def apply_energy_steering(logits, target_phrase=\"Python code\", strength=2.0):\n",
        "    \"\"\"\n",
        "    Bias the energy surface toward tokens that appear in target_phrase.\n",
        "    Adds `strength` to each matching token's logit, shifting the\n",
        "    Boltzmann distribution without retraining.\n",
        "    \"\"\"\n",
        "    target_tokens = tokenizer.encode(target_phrase, add_special_tokens=False)\n",
        "    steer_vector = jnp.zeros_like(logits)\n",
        "    for token_id in target_tokens:\n",
        "        steer_vector = steer_vector.at[0, token_id].add(strength)\n",
        "    return logits + steer_vector\n",
        "\n",
        "print(\"Energy steering function ready.\")\n"
