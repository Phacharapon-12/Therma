      "source": [
        "import jax\n",
        "import jax.numpy as jnp\n",
        "import torch\n",
        "from thrml import CategoricalNode\n",
        "\n",
        "class QwenTHRMLPGMEngine(QwenDTMHybridAdvanced):\n",
        "    \"\"\"\n",
        "    Fully probabilistic engine using THRML PGM structures.\n",
        "    Represents the token generation as a physics simulation of a node in an energy field.\n",
        "    \"\"\"\n",
        "    def __init__(self, transformer_model, dtm_weights, tokenizer):\n",
        "        super().__init__(transformer_model, dtm_weights, tokenizer)\n",
        "        self.token_node = CategoricalNode()\n",
        "\n",
        "    def generate(self, prompt, max_new_tokens=50, temperature=0.7):\n",
        "        generated_ids = self.tokenizer(prompt, return_tensors=\"pt\").input_ids[0].tolist()\n",
        "        print(f\"[THRML-PGM-Native] {prompt}\\n\", end=\"\", flush=True)\n",
        "\n",
        "        beta = 1.0 / (temperature + 1e-8)\n",
        "        key = jax.random.PRNGKey(42)\n",
