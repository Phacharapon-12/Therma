        "        beta = 1.0 / (temperature + 1e-8)\n",
        "        key = jax.random.PRNGKey(int(time.time()))\n",
        "\n",
        "        # Track which TSU unit is 'ready' (equilibrated)\n",
        "        active_unit = 0\n",
        "\n",
        "        print(f'\\n[Dual-TSU 512-Node Ping-Pong] {prompt}\\n', end='', flush=True)\n",
