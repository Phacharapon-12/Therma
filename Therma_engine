        "import jax\n",
        "import jax.numpy as jnp\n",
        "import time\n",
        "\n",
        "class QwenDualPingPongEngine(QwenMasterDTMEngine):\n",
        "    def __init__(self, model, weights, tokenizer, total_nodes=512):\n",
        "        # Initialize with 512 nodes split across two 'virtual' hardware units\n",
        "        super().__init__(model, weights, tokenizer, num_nodes=total_nodes)\n",
