      "source": [
        "# ── Thermodynamic Sampling Engine ───────────────────────────────────────\n",
        "# Maps neural network logits onto a physical energy landscape:\n",
        "#   E(token) = -logit(token)\n",
        "#   P(token) = exp(-β·E) / Z   (Boltzmann / Gibbs distribution)\n",
        "#   β = 1/T  (inverse temperature)\n",
        "# Low temperature → peaked distribution (deterministic)\n",
        "# High temperature → flat distribution (random)\n",
        "\n",
        "def calculate_boltzmann_probs(energy_surface, temperature=1.0):\n",
        "    beta = 1.0 / (temperature + 1e-8)\n",
        "    energies = -energy_surface                                   # E = -logits\n",
        "    exp_factor = jnp.exp(-beta * energies)                       # exp(-β·E)\n",
        "    partition_function = jnp.sum(exp_factor, axis=-1, keepdims=True)  # Z\n",
        "    return exp_factor / partition_function\n",
        "\n",
        "def calculate_free_energy(energies, probs, temperature):\n",
        "    \"\"\"Helmholtz Free Energy: F = <E> - T·S\"\"\"\n",
        "    avg_energy = jnp.sum(probs * energies)\n",
        "    entropy = -jnp.sum(probs * jnp.log(probs + 1e-10))\n",
        "    return avg_energy - (temperature * entropy), entropy\n",
        "\n",
        "print(\"Thermodynamic engine ready (Boltzmann + Free Energy).\")\n"
      ],
