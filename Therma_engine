      "source": [
        "import time\n",
        "import torch\n",
        "import jax\n",
        "import jax.numpy as jnp\n",
        "\n",
        "\n",
        "class QwenDTMHybrid:\n",
        "    \"\"\"Base class: Qwen hidden states → JAX DTM projection → token sampling.\"\"\"\n",
        "\n",
        "    def __init__(self, transformer_model, dtm_weights, tokenizer, device=\"cuda\"):\n",
        "        self.model = transformer_model\n",
        "        self.dtm_weights = dtm_weights\n",
        "        self.tokenizer = tokenizer\n",
        "        self.device = device\n",
        "\n",
        "    def _hidden_state(self, token_ids):\n",
        "        with torch.no_grad():\n",
        "            out = self.model.model(torch.tensor([token_ids]).to(self.device))\n",
        "            return self.model.model.norm(out.last_hidden_state[:, -1, :])\n",
        "\n",
        "    def generate(self, prompt, max_new_tokens=30, temperature=0.7):\n",
        "        generated_ids = self.tokenizer(\n",
        "            prompt, return_tensors=\"pt\"\n",
        "        ).input_ids[0].tolist()\n",
        "        for _ in range(max_new_tokens):\n",
        "            h_jax = jnp.array(\n",
        "                self._hidden_state(generated_ids).to(torch.float32).cpu().numpy()\n",
        "            )\n",
        "            logits = jnp.dot(h_jax, self.dtm_weights) / (temperature + 1e-8)\n",
        "            key = jax.random.PRNGKey(int(time.time() * 1000) % 100000)\n",
        "            next_id = int(jax.random.categorical(key, logits)[0])\n",
        "            if next_id == self.tokenizer.eos_token_id:\n",
        "                break\n",
        "            generated_ids.append(next_id)\n",
        "        return self.tokenizer.decode(generated_ids)\n",
        "\n",
        "\n",
        "class QwenDTMHybridAdvanced(QwenDTMHybrid):\n",
        "    \"\"\"\n",
        "    Full pipeline:\n",
        "      - System-prompt prefix\n",
        "      - Repetition penalty   (divides/multiplies logit by penalty factor)\n",
        "      - Top-K filtering      (keep only K highest-energy tokens)\n",
        "      - Top-P (nucleus) sampling\n",
        "      - Optional energy steering  (bias logits toward a target phrase)\n",
        "    \"\"\"\n",
        "\n",
        "    def generate(\n",
        "        self, prompt,\n",
        "        max_new_tokens=150, temperature=0.2,\n",
        "        repetition_penalty=1.5, top_p=0.7, top_k=40,\n",
        "        steering_phrase=None, steering_strength=2.0\n",
        "    ):\n",
        "        full_prompt = (\n",
        "            \"You are a helpful assistant. Answer concisely:\\nUser: \"\n",
        "            + prompt + \"\\nAssistant: \"\n",
        "        )\n",
        "        generated_ids = self.tokenizer(\n",
        "            full_prompt, return_tensors=\"pt\"\n",
        "        ).input_ids[0].tolist()\n",
        "\n",
        "        print(f\"Prompt: {prompt}\\n\", end=\"\", flush=True)\n",
        "\n",
        "        for _ in range(max_new_tokens):\n",
        "            h_jax = jnp.array(\n",
        "                self._hidden_state(generated_ids).to(torch.float32).cpu().numpy()\n",
        "            )\n",
        "            logits = jnp.dot(h_jax, self.dtm_weights) / (temperature + 1e-8)\n",
        "\n",
        "            # Energy steering\n",
        "            if steering_phrase:\n",
        "                logits = apply_energy_steering(logits, steering_phrase, steering_strength)\n",
        "\n",
        "            # Repetition penalty\n",
        "            for token_id in set(generated_ids):\n",
        "                if logits[0, token_id] > 0:\n",
        "                    logits = logits.at[0, token_id].set(\n",
        "                        logits[0, token_id] / repetition_penalty\n",
        "                    )\n",
        "                else:\n",
        "                    logits = logits.at[0, token_id].set(\n",
        "                        logits[0, token_id] * repetition_penalty\n",
        "                    )\n",
        "\n",
        "            # Top-K filter\n",
        "            top_k_vals, _ = jax.lax.top_k(logits, k=top_k)\n",
        "            min_k = jnp.min(top_k_vals, axis=-1, keepdims=True)\n",
        "            logits = jnp.where(logits < min_k, -1e10, logits)\n",
        "\n",
        "            # Top-P (nucleus) filter\n",
        "            sorted_idx = jnp.argsort(logits[0])[::-1]\n",
        "            sorted_logits = logits[0, sorted_idx]\n",
        "            cum_probs = jnp.cumsum(jax.nn.softmax(sorted_logits))\n",
        "            cutoff = sorted_logits[jnp.sum(cum_probs < top_p)]\n",
        "            logits = jnp.where(logits < cutoff, -1e10, logits)\n",
        "\n",
        "            key = jax.random.PRNGKey(int(time.time() * 1000) % 100000)\n",
        "            next_id = int(jax.random.categorical(key, logits)[0])\n",
        "            if next_id == self.tokenizer.eos_token_id:\n",
        "                break\n",
        "            generated_ids.append(next_id)\n",
        "            print(\n",
        "                self.tokenizer.decode([next_id]).replace('\\n', ' ').strip() + ' ',\n",
        "                end=\"\", flush=True\n",
        "            )\n",
        "\n",
        "        return self.tokenizer.decode(generated_ids)\n",
        "\n",
        "\n",
        "class QwenDTMPhysicsEngine(QwenDTMHybridAdvanced):\n",
        "    \"\"\"\n",
        "    Replaces softmax sampling with Boltzmann / Gibbs sampling:\n",
        "      P(token) ∝ exp(β · logit)  where β = 1/T\n",
        "    Tokens are drawn from the full probability distribution,\n",
        "    mirroring thermal fluctuations in a physical system.\n",
        "    \"\"\"\n",
        "\n",
        "    def generate(self, prompt, max_new_tokens=50, temperature=0.7):\n",
        "        generated_ids = self.tokenizer(\n",
        "            prompt, return_tensors=\"pt\"\n",
        "        ).input_ids[0].tolist()\n",
        "        print(f\"[Physics-Inference] {prompt}\\n\", end=\"\", flush=True)\n",
        "\n",
        "        for _ in range(max_new_tokens):\n",
        "            h_jax = jnp.array(\n",
        "                self._hidden_state(generated_ids).to(torch.float32).cpu().numpy()\n",
        "            )\n",
        "            logits = jnp.dot(h_jax, self.dtm_weights)\n",
        "            probs = calculate_boltzmann_probs(logits, temperature)  # Gibbs dist.\n",
        "            key = jax.random.PRNGKey(int(time.time() * 1000) % 100000)\n",
        "            next_id = int(\n",
        "                jax.random.choice(key, a=probs.shape[-1], p=probs[0])\n",
        "            )\n",
        "            if next_id == self.tokenizer.eos_token_id:\n",
        "                break\n",
        "            generated_ids.append(next_id)\n",
        "            print(self.tokenizer.decode([next_id]), end=\"\", flush=True)\n",
        "\n",
        "        return self.tokenizer.decode(generated_ids)\n",
        "\n",
        "\n",
        "# Instantiate all three variants\n",
        "tsu_model        = QwenDTMHybrid(model, projection_weights, tokenizer)\n",
        "tsu_model_v2     = QwenDTMHybridAdvanced(model, projection_weights, tokenizer)\n",
        "tsu_physics_model = QwenDTMPhysicsEngine(model, projection_weights, tokenizer)\n",
        "\n",
        "print(\"All model variants ready.\")\n"
      ],
