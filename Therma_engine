        "        for i in range(max_new_tokens):\n",
        "            h_jax = self._get_hidden_state(generated_ids)\n",
        "            all_logits = jnp.dot(h_jax, self.dtm_weights)[0]\n",
        "\n",
        "            # Map logits to the 512-node structure\n",
        "            padded_logits = jnp.pad(all_logits, (0, self.total_capacity - all_logits.shape[-1]), constant_values=-1e20)\n",
